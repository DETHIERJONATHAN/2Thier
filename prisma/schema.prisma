// ═══════════════════════════════════════════════════════
// CHANTIER WORKFLOW — Transitions, Factures, Événements, Historique
// Tout est modulable et configurable par organisation
// ═══════════════════════════════════════════════════════

// Règles de transition entre colonnes du kanban (configurables par org)
model ChantierStatusTransition {
  id                 String   @id
  organizationId     String
  fromStatusId       String
  toStatusId         String
  triggerType        String   @default("MANUAL") // MANUAL | AUTO_INVOICE_PAID | AUTO_MATERIAL_RECEIVED | AUTO_VISIT_VALIDATED | AUTO_CLIENT_SIGNED | AUTO_DATE_REACHED
  requiredConditions Json?    // {"invoiceType": "ACOMPTE", "allPaid": true} etc.
  allowedRoles       Json?    // ["admin", "comptable", "super_admin"] — qui peut drag-drop
  notifyRoles        Json?    // ["commercial", "admin"] — qui reçoit notification
  sendEmail          Boolean  @default(false)
  emailTemplateId    String?  // optionnel : template email à envoyer
  label              String?  // "Passage auto après paiement acompte"
  isActive           Boolean  @default(true)
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime

  Organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  FromStatus         ChantierStatus  @relation("TransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ToStatus           ChantierStatus  @relation("TransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId])
  @@index([fromStatusId])
  @@index([organizationId, triggerType])
}

// Templates de factures associés à un statut (configurables par org)
// Plan de facturation spécifique à un chantier (copié depuis les templates puis personnalisable)
model ChantierBillingPlanItem {
  id             String   @id
  chantierId     String
  organizationId String
  statusId       String?  // à quel statut cette facture est associée
  type           String   @default("CUSTOM") // ACOMPTE | MATERIEL | FIN_CHANTIER | RECEPTION | CUSTOM
  label          String
  percentage     Float?   // ex: 30.0 pour 30%
  fixedAmount    Float?   // montant fixe alternatif
  isRequired     Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  Chantier       Chantier        @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Status         ChantierStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([chantierId])
  @@index([organizationId])
}

// Templates de facturation globaux par organisation (config admin)
model ChantierInvoiceTemplate {
  id             String   @id
  organizationId String
  statusId       String?  // à quel statut cette facture est associée (null = global)
  type           String   @default("CUSTOM") // ACOMPTE | MATERIEL | FIN_CHANTIER | RECEPTION | CUSTOM
  label          String   // "Facture acompte 30%"
  percentage     Float?   // ex: 30.0 pour 30%
  fixedAmount    Float?   // montant fixe alternatif
  isRequired     Boolean  @default(false) // doit être payée pour passer au statut suivant
  isActive       Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  Organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Status         ChantierStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([organizationId])
  @@index([organizationId, statusId])
}

// Factures réelles liées à un chantier
model ChantierInvoice {
  id                    String    @id
  chantierId            String
  organizationId        String
  type                  String    @default("CUSTOM") // ACOMPTE | MATERIEL | FIN_CHANTIER | RECEPTION | CUSTOM
  label                 String
  amount                Float
  percentage            Float?    // % du montant total du devis
  status                String    @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  dueDate               DateTime?
  paidAt                DateTime?
  sentAt                DateTime?
  documentUrl           String?   // lien vers le PDF
  generatedDocumentId   String?   // lien vers le système de documents TBL
  invoiceNumber         String?   // numéro de facture
  notes                 String?
  order                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime

  Chantier              Chantier       @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([chantierId])
  @@index([organizationId])
  @@index([chantierId, status])
  @@index([organizationId, status])
}

// Événements liés à un chantier (visites, chantier, réception) — lien vers CalendarEvent
model ChantierEvent {
  id               String    @id
  chantierId       String
  calendarEventId  String?
  type             String    @default("CUSTOM") // VISITE_TECHNIQUE | CHANTIER | RECEPTION | CUSTOM
  status           String    @default("PLANNED") // PLANNED | COMPLETED | CANCELLED | PROBLEM
  problemNote      String?   // note si problème signalé par technicien
  validatedAt      DateTime?
  validatedById    String?   // qui a validé
  subcontractAmount Float?   // montant sous-traitance fixé après validation
  subcontractLocked Boolean  @default(false) // verrouillé après validation
  notes            String?
  reviewStatus     String?   // PENDING | CONFIRMED | CHANGES_DETECTED
  reviewData       Json?     // snapshot des données de revue
  createdAt        DateTime  @default(now())
  updatedAt        DateTime

  Chantier         Chantier       @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  CalendarEvent    CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  ValidatedBy      User?          @relation("ChantierEventValidator", fields: [validatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  TechnicianFieldReviews TechnicianFieldReview[]

  @@index([chantierId])
  @@index([calendarEventId])
  @@index([chantierId, type])
}

// Historique complet de toutes les actions sur un chantier
model ChantierHistory {
  id          String   @id
  chantierId  String
  action      String   // STATUS_CHANGED | INVOICE_CREATED | INVOICE_PAID | EVENT_PLANNED | EVENT_VALIDATED | PROBLEM_REPORTED | NOTE_ADDED | SUBCONTRACT_LOCKED | DRAG_DROP
  fromValue   String?  // ancienne valeur (ex: ancien statut)
  toValue     String?  // nouvelle valeur (ex: nouveau statut)
  userId      String?  // qui a fait l'action
  data        Json?    // détails supplémentaires
  createdAt   DateTime @default(now())

  Chantier    Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User        User?    @relation("ChantierHistoryUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([chantierId])
  @@index([chantierId, action])
  @@index([chantierId, createdAt])
}

// ═══════════════════════════════════════════════════
// ═══ Techniciens & Équipes ═══════════════════════
// ═══════════════════════════════════════════════════

enum TechnicianType {
  INTERNAL
  SUBCONTRACTOR
}

enum BillingMode {
  FORFAIT   // Sous-traitant au forfait (pas de pointage)
  REGIE     // Sous-traitant en régie (pointage requis)
}

enum TimeEntryType {
  CHANTIER        // Travail sur chantier (legacy)
  DEPLACEMENT     // Trajet (legacy)
  PAUSE           // Pause (legacy)
  REGIE           // Heures en régie sous-traitant (legacy)
  ARRIVEE         // Arrivée sur chantier
  DEPART_PAUSE    // Départ en pause
  RETOUR_PAUSE    // Retour de pause
  DEPART_MIDI     // Départ midi
  RETOUR_MIDI     // Retour de midi
  DEPART_DEPLACEMENT // Départ en déplacement
  RETOUR_DEPLACEMENT // Retour de déplacement
  FIN             // Fin de journée / départ du chantier
}

model Technician {
  id             String          @id @default(cuid())
  organizationId String
  userId         String?         // null pour sous-traitants, lié pour internes
  type           TechnicianType  @default(INTERNAL)
  billingMode    BillingMode?    // null pour internes, FORFAIT ou REGIE pour sous-traitants
  firstName      String
  lastName       String
  email          String?
  phone          String?
  company        String?         // Société du sous-traitant
  vatNumber      String?         // Numéro de TVA (obligatoire pour sous-traitants)
  address        String?         // Adresse (rue + numéro)
  postalCode     String?         // Code postal
  city           String?         // Ville
  country        String?         @default("Belgique") // Pays
  iban           String?         // Compte bancaire (IBAN)
  specialties    String[]        @default([]) // productValue[] : ["pc", "all", "toiture"]
  hourlyRate     Float?
  notes          String?
  color          String          @default("#1677ff")
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  Organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User                User?                     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  TeamMemberships     TeamMember[]
  ChantierAssignments ChantierAssignment[]
  Unavailabilities    TechnicianUnavailability[]
  TimeEntries         TimeEntry[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model TimeEntry {
  id             String        @id @default(cuid())
  organizationId String
  technicianId   String
  chantierId     String?       // null si pointage hors-chantier
  date           DateTime      @db.Date
  startTime      DateTime      // Heure d'arrivée
  endTime        DateTime?     // Heure de départ (null = en cours)
  breakMinutes   Int           @default(0)  // Durée pause en minutes
  type           TimeEntryType @default(CHANTIER)
  durationMinutes Int?         // Calculé: endTime - startTime - breakMinutes
  note           String?

  // 📍 Géolocalisation anti-fraude
  clockInLatitude    Float?    // GPS arrivée
  clockInLongitude   Float?
  clockInAddress     String?   // Adresse inversée arrivée
  clockInDistance     Int?     // Distance en mètres par rapport au chantier
  clockOutLatitude   Float?    // GPS départ
  clockOutLongitude  Float?
  clockOutAddress    String?   // Adresse inversée départ
  clockOutDistance    Int?     // Distance en mètres par rapport au chantier

  // 📸 Photos anti-fraude
  clockInPhotoUrl    String?   // Photo prise à l'arrivée
  clockOutPhotoUrl   String?   // Photo prise au départ

  // 📱 Empreinte appareil
  deviceInfo         Json?     // { userAgent, platform, screenWidth, screenHeight, deviceId }
  ipAddress          String?   // IP côté serveur

  validatedBy    String?       // userId du validateur
  validatedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  Organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Technician   Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Chantier     Chantier?    @relation(fields: [chantierId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([organizationId, date])
  @@index([technicianId, date])
  @@index([chantierId])
}

enum UnavailabilityType {
  CONGE
  FORMATION
  MALADIE
  AUTRE
}

model TechnicianUnavailability {
  id           String             @id @default(cuid())
  technicianId String
  startDate    DateTime
  endDate      DateTime
  type         UnavailabilityType @default(AUTRE)
  allDay       Boolean            @default(true)
  note         String?
  createdAt    DateTime           @default(now())

  Technician   Technician         @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([technicianId])
  @@index([startDate, endDate])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String       @default("#1677ff")
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  Organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Members             TeamMember[]
  ChantierAssignments ChantierAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum TeamMemberRole {
  LEADER
  MEMBER
}

model TeamMember {
  id           String         @id @default(cuid())
  teamId       String
  technicianId String
  role         TeamMemberRole @default(MEMBER)
  createdAt    DateTime       @default(now())

  Team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([teamId, technicianId])
  @@index([technicianId])
}

// ═══════════════════════════════════════════════════
// REVUE TECHNIQUE — Données de validation par le technicien
// ═══════════════════════════════════════════════════
model TechnicianFieldReview {
  id                String    @id @default(cuid())
  chantierEventId   String
  nodeId            String    // champ TBL concerné
  fieldLabel        String    // snapshot du label
  originalValue     String?   // valeur du commercial (gelée)
  reviewedValue     String?   // valeur du technicien
  isModified        Boolean   @default(false)
  modificationNote  String?   // raison si modifié (obligatoire)
  reviewType        String    @default("TECHNICAL") // TECHNICAL | RECEPTION
  reviewedById      String
  reviewedAt        DateTime  @default(now())

  ChantierEvent     ChantierEvent @relation(fields: [chantierEventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ReviewedBy        User          @relation("TechnicianReviewer", fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([chantierEventId, nodeId, reviewType])
  @@index([chantierEventId])
  @@index([reviewedById])
}

// ═══════════════════════════════════════════════════
// RÉCEPTION CHANTIER — PV de réception client (juridique)
// ═══════════════════════════════════════════════════
model ChantierReception {
  id                    String    @id @default(cuid())
  chantierId            String    @unique // 1 réception par chantier
  chantierEventId       String?   // lié à l'événement RECEPTION

  // État du PV
  status                String    @default("DRAFT")
  // DRAFT | PENDING_CLIENT | ACCEPTED | ACCEPTED_WITH_RESERVES | REFUSED

  // Données du chantier (snapshot gelé)
  workSummary           Json?     // résumé des travaux réalisés
  checklist             Json?     // [{label, checked, note?}] points de contrôle

  // Satisfaction client (questions)
  satisfactionRating    Int?      // 1-5 étoiles
  satisfactionAnswers   Json?     // [{question, answer, rating}]

  // Signature client (juridiquement fort)
  clientName            String?   // nom du signataire
  clientEmail           String?   // email pour envoi du PV
  clientPhone           String?   // téléphone
  clientSignature       String?   // base64 de la signature manuscrite
  clientSignedAt        DateTime?
  clientIpAddress       String?   // IP au moment de la signature
  clientUserAgent       String?   // navigateur utilisé
  clientAccessToken     String?   @unique // lien sécurisé sans login
  clientTokenExpiresAt  DateTime? // expiration du lien

  // Clause légale acceptée
  legalText             String?   // texte contractuel affiché au client
  legalAccepted         Boolean   @default(false)
  legalAcceptedAt       DateTime?

  // Réserves
  hasReserves           Boolean   @default(false)
  reserves              Json?     // [{description, photo?, severity, deadline?}]
  reservesResolvedAt    DateTime?
  reservesResolvedById  String?

  // Montants
  totalAmount           Float?    // montant TTC devis
  subcontractTotal      Float?    // somme sous-traitance

  // Traçabilité
  preparedById          String?   // technicien qui prépare
  preparedAt            DateTime  @default(now())
  updatedAt             DateTime

  Chantier              Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clientAccessToken])
  @@index([chantierId])
  @@index([status])
}

enum ChantierAssignmentRole {
  CHEF_EQUIPE
  TECHNICIEN
}

model ChantierAssignment {
  id           String                  @id @default(cuid())
  chantierId   String
  technicianId String
  teamId       String?
  role         ChantierAssignmentRole  @default(TECHNICIEN)
  assignedAt   DateTime                @default(now())

  Chantier   Chantier   @relation(fields: [chantierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Team       Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([chantierId, technicianId])
  @@index([chantierId])
  @@index([technicianId])
  @@index([teamId])
}

// ═══════════════════════════════════════════════════
// SIGNATURE ÉLECTRONIQUE AVANCÉE (eIDAS niveau avancé, 100% maison)
// ═══════════════════════════════════════════════════
model ElectronicSignature {
  id                String    @id @default(cuid())
  
  // Contexte du document
  submissionId      String?   // TBL submission signée
  documentId        String?   // GeneratedDocument lié
  leadId            String?   // Lead associé
  organizationId    String
  
  // Type de signature
  signatureType     String    @default("DEVIS")
  // DEVIS | RECTIFICATION | CONTRAT | PV_RECEPTION
  
  // Signataires
  signerRole        String    // CLIENT | COMMERCIAL | TECHNICIEN
  signerName        String    // Nom complet du signataire
  signerEmail       String    // Email du signataire
  signerPhone       String?   // Téléphone (optionnel)
  
  // Signature visuelle
  signatureData     String    // base64 PNG de la signature manuscrite (canvas)
  signatureHash     String    // SHA-256 du signatureData
  
  // Vérification OTP (niveau avancé eIDAS)
  otpCode           String?   // Code OTP hashé (SHA-256)
  otpSentAt         DateTime? // Quand l'OTP a été envoyé
  otpVerifiedAt     DateTime? // Quand l'OTP a été vérifié
  otpMethod         String?   @default("EMAIL") // EMAIL | SMS
  otpAttempts       Int       @default(0) // Nombre de tentatives
  
  // Scellement cryptographique du document
  documentHash      String?   // SHA-256 du PDF au moment de la signature
  documentSnapshot  Json?     // Données du document gelées au moment de signature
  
  // Clause légale
  legalText         String?   // Texte juridique affiché et accepté
  legalAccepted     Boolean   @default(false)
  legalAcceptedAt   DateTime?
  
  // Métadonnées juridiques (piste d'audit)
  ipAddress         String?   // IP au moment de la signature
  userAgent         String?   // Navigateur/OS
  geoLocation       String?   // Localisation approximative (optionnel)
  
  // Token d'accès (pour signature sans login - ex: client)
  accessToken       String?   @unique
  tokenExpiresAt    DateTime?
  
  // État
  status            String    @default("PENDING")
  // PENDING | OTP_SENT | OTP_VERIFIED | SIGNED | EXPIRED | REVOKED
  signedAt          DateTime?
  expiresAt         DateTime? // Date d'expiration de la demande
  revokedAt         DateTime?
  revokedReason     String?
  
  // PDF signé final
  signedPdfUrl      String?   // URL du PDF avec signature intégrée
  signedPdfHash     String?   // SHA-256 du PDF signé final
  
  // Traçabilité
  createdBy         String?   // Qui a initié la demande de signature
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Audit trail (log détaillé de toutes les actions)
  auditTrail        Json?     // [{action, timestamp, ip, userAgent, details}]
  
  @@index([submissionId])
  @@index([documentId])
  @@index([leadId])
  @@index([organizationId])
  @@index([signerEmail])
  @@index([accessToken])
  @@index([status])
  @@index([signatureType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// RÉSEAU SOCIAL D'ENTREPRISE — MUR / WALL
// ═══════════════════════════════════════════════════════════════

model WallPost {
  id              String    @id @default(uuid())
  organizationId  String?
  authorId        String

  // Contenu
  content         String?
  mediaUrls       Json?               // ["url1.jpg", "video.mp4"]
  mediaType       String?             // "image", "video", "document", "gallery"

  // Visibilité : OUT (privé), IN (organisation), ALL (toutes orgas), CLIENT (client spécifique)
  visibility      String              @default("IN")
  targetLeadId    String?             // Si visibility=CLIENT → quel client voit ce post

  // Liaison CRM automatique
  crmEventType    String?             // DEVIS_SIGNE, COMMANDE, RECEPTION_COMMANDE, PLANIFICATION,
                                      // CHANTIER_EN_COURS, FIN_CHANTIER, RECEPTION, FACTURE,
                                      // TERMINE, SAV, DOCUMENT, NOUVEAU_LEAD, EMAIL_ENVOYE,
                                      // RDV_PLANIFIE, APPEL_EFFECTUE
  crmEntityType   String?             // "Chantier", "Lead", "Quote", "ChantierInvoice"
  crmEntityId     String?

  // Catégorie pour filtrage
  category        String?             // "projet", "actualite", "chantier_realise", "conseil", "promotion"

  // Publication en tant qu'organisation
  publishAsOrg    Boolean   @default(false)

  // SpaceFlow
  tags            String[]  @default([])  // hashtags extraits du contenu
  isAnonymous     Boolean   @default(false) // mode Spark
  parentPostId    String?                  // Echo/remix d'un autre post

  // Compteurs dénormalisés
  likesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)

  isPinned        Boolean   @default(false)
  isPublished     Boolean   @default(true)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author          User         @relation("WallPostAuthor", fields: [authorId], references: [id])
  targetLead      Lead?        @relation("WallPostTargetLead", fields: [targetLeadId], references: [id])
  reactions       WallReaction[]
  comments        WallComment[]
  shares          WallShare[]
  hashtags        PostHashtag[]
  parentPost      WallPost?    @relation("PostEcho", fields: [parentPostId], references: [id], onDelete: SetNull)
  echoes          WallPost[]   @relation("PostEcho")
  savedBy         SavedReel[]

  @@index([organizationId, visibility, createdAt])
  @@index([organizationId, createdAt])
  @@index([targetLeadId, createdAt])
  @@index([organizationId, category, createdAt])
  @@index([authorId, createdAt])
  @@index([crmEntityType, crmEntityId])
}

model WallReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String   @default("LIKE")  // LIKE, LOVE, BRAVO, UTILE, WOW
  createdAt DateTime @default(now())

  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("WallReactionUser", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model WallComment {
  id              String    @id @default(uuid())
  postId          String
  authorId        String
  parentCommentId String?
  organizationId  String?

  content         String
  mediaUrl        String?
  publishAsOrg    Boolean   @default(false)

  isEdited        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post            WallPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          User         @relation("WallCommentAuthor", fields: [authorId], references: [id])
  organization    Organization? @relation("WallCommentOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  parentComment   WallComment? @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         WallComment[] @relation("CommentReplies")
  likes           CommentLike[]

  @@index([postId, createdAt])
  @@index([authorId])
}

model WallShare {
  id          String   @id @default(uuid())
  postId      String
  userId      String
  targetType  String   // INTERNAL, FACEBOOK, LINKEDIN, WHATSAPP, EMAIL, LINK
  targetUrl   String?
  createdAt   DateTime @default(now())

  post        WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User     @relation("WallShareUser", fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
}

model ClientAccount {
  id              String    @id @default(uuid())
  userId          String    @unique
  leadId          String
  organizationId  String

  isActive        Boolean   @default(true)
  activatedAt     DateTime  @default(now())
  lastLoginAt     DateTime?

  notifyEmail     Boolean   @default(true)
  notifyPush      Boolean   @default(true)
  notifyWhatsApp  Boolean   @default(false)

  referralCode    String?   @unique
  referredBy      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead            Lead         @relation(fields: [leadId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([leadId])
}

model PushSubscription {
  id              String    @id @default(uuid())
  userId          String
  endpoint        String    @unique
  p256dh          String
  auth            String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserPhoto {
  id        String   @id @default(uuid())
  userId    String
  url       String
  category  String   @default("other")
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

// ═══════════════════════════════════════════════════════
// FRIENDS SYSTEM
// ═══════════════════════════════════════════════════════

model Friendship {
  id            String   @id @default(uuid())
  requesterId   String
  addresseeId   String
  status        String   @default("pending") // pending, accepted, blocked
  source        String   @default("manual")  // manual, organization (auto-added)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requester     User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee     User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

// ═══════════════════════════════════════════════════════
// MESSENGER SYSTEM
// ═══════════════════════════════════════════════════════

model Conversation {
  id            String   @id @default(uuid())
  name          String?  // null for 1-to-1, set for groups
  isGroup       Boolean  @default(false)
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  participants  ConversationParticipant[]
  messages      Message[]
  videoCalls    VideoCall[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String   @id @default(uuid())
  conversationId  String
  userId          String
  role            String   @default("member") // member, admin
  lastReadAt      DateTime @default(now())
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, isActive])
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String
  senderId        String
  content         String?
  mediaUrls       Json?    // ["url1", "url2"]
  mediaType       String?  // image, video, file
  replyToId       String?
  isEdited        Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo         Message?     @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageReply")

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ═══════════════════════════════════════════════════════
// VIDEO CALLS & MEETINGS
// ═══════════════════════════════════════════════════════

model VideoCall {
  id              String   @id @default(uuid())
  conversationId  String?
  initiatorId     String
  title           String?
  status          String   @default("ringing") // ringing, active, ended, missed
  callType        String   @default("video")   // video, audio
  startedAt       DateTime?
  endedAt         DateTime?
  duration        Int?     // seconds
  recordingUrl    String?
  transcription   String?  @db.Text
  meetingSummary  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  initiator       User          @relation("VideoCallInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  participants    CallParticipant[]

  @@index([conversationId])
  @@index([initiatorId])
  @@index([status])
}

model CallParticipant {
  id          String   @id @default(uuid())
  callId      String
  userId      String
  status      String   @default("invited") // invited, joined, left, rejected
  joinedAt    DateTime?
  leftAt      DateTime?
  isMuted     Boolean  @default(false)
  isVideoOff  Boolean  @default(false)

  call        VideoCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([userId, status])
}

// ═══════════════════════════════════════════════════════════════
// SPACEFLOW — RÉSEAU SOCIAL NOUVELLE GÉNÉRATION
// ═══════════════════════════════════════════════════════════════

// ── FOLLOW (asymétrique, parallèle au système Friendship) ──

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── STORIES (contenu éphémère 24h) ──

model Story {
  id             String    @id @default(uuid())
  authorId       String
  organizationId String?
  mediaUrl       String                    // URL image/vidéo
  mediaType      String    @default("image") // image, video
  caption        String?
  musicUrl       String?
  duration       Int       @default(5)     // secondes d'affichage
  visibility     String    @default("ALL") // ALL, IN, OUT
  publishAsOrg   Boolean   @default(false)
  isHighlight    Boolean   @default(false) // garder en "à la une"
  highlightName  String?                   // nom du highlight
  expiresAt      DateTime                  // maintenant + 24h
  createdAt      DateTime  @default(now())

  author         User       @relation("StoryAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  views          StoryView[]

  @@index([authorId, createdAt])
  @@index([expiresAt])
  @@index([organizationId])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())

  story     Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer    User  @relation("StoryViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
  @@index([storyId])
  @@index([viewerId])
}

// ── HASHTAGS ──

model Hashtag {
  id         String   @id @default(uuid())
  name       String   @unique  // stocké en minuscule sans #
  postCount  Int      @default(0)
  createdAt  DateTime @default(now())

  posts      PostHashtag[]

  @@index([postCount])
}

model PostHashtag {
  id        String   @id @default(uuid())
  postId    String
  hashtagId String
  createdAt DateTime @default(now())

  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

// ── SPARK (posts anonymes avec révélation) ──

model Spark {
  id             String    @id @default(uuid())
  authorId       String
  organizationId String?
  content        String?
  mediaUrl       String?
  mediaType      String?             // image, video
  sparkCount     Int       @default(0) // votes "spark"
  revealThreshold Int      @default(100)
  isRevealed     Boolean   @default(false)
  visibility     String    @default("ALL") // ALL, IN, OUT
  publishAsOrg   Boolean   @default(false)
  revealedAt     DateTime?
  createdAt      DateTime  @default(now())

  author         User         @relation("SparkAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  votes          SparkVote[]
  dismissals     SparkDismiss[]

  @@index([isRevealed, sparkCount])
  @@index([createdAt])
  @@index([organizationId])
}

model SparkVote {
  id        String   @id @default(uuid())
  sparkId   String
  voterId   String
  createdAt DateTime @default(now())

  spark     Spark @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  voter     User  @relation("SparkVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([sparkId, voterId])
  @@index([sparkId])
}

// ── BATTLES (duels créatifs) ──

model Battle {
  id             String    @id @default(uuid())
  organizationId String?
  title          String                   // "Meilleure photo du jour"
  description    String?
  challengerId   String
  opponentId     String?                  // null = ouvert à tous
  status         String    @default("open") // open, active, voting, ended
  startsAt       DateTime  @default(now())
  endsAt         DateTime                 // deadline
  winnerId       String?
  createdAt      DateTime  @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  challenger     User          @relation("BattleChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent       User?         @relation("BattleOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  winner         User?         @relation("BattleWinner", fields: [winnerId], references: [id], onDelete: Cascade)
  entries        BattleEntry[]

  @@index([status, endsAt])
  @@index([createdAt])
}

model BattleEntry {
  id        String   @id @default(uuid())
  battleId  String
  userId    String
  content   String?
  mediaUrl  String?
  mediaType String?
  votes     Int      @default(0)
  createdAt DateTime @default(now())

  battle    Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user      User   @relation("BattleEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId])
  @@index([battleId, votes])
}

// ── TIME CAPSULES ──

model TimeCapsule {
  id             String    @id @default(uuid())
  authorId       String
  organizationId String?
  content        String?
  mediaUrl       String?
  mediaType      String?
  unlocksAt      DateTime         // date d'ouverture
  isOpened       Boolean   @default(false)
  recipientId    String?          // null = public, sinon destinataire
  createdAt      DateTime  @default(now())

  author         User          @relation("CapsuleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  recipient      User?         @relation("CapsuleRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([unlocksAt, isOpened])
  @@index([authorId])
  @@index([recipientId])
}

// ── QUESTS (missions gamifiées) ──

model Quest {
  id             String    @id @default(uuid())
  organizationId String?            // null = quests globales SpaceFlow
  sponsorId      String?            // entreprise qui sponsorise
  title          String
  description    String?
  icon           String    @default("🎯")
  questType      String    @default("daily") // daily, weekly, monthly, special
  actionType     String                     // post_photo, comment, react, visit, share
  targetCount    Int       @default(1)      // combien de fois
  rewardPoints   Int       @default(10)
  isActive       Boolean   @default(true)
  startsAt       DateTime  @default(now())
  endsAt         DateTime?
  createdAt      DateTime  @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsor        User?         @relation("QuestSponsor", fields: [sponsorId], references: [id])
  progress       QuestProgress[]

  @@index([isActive, questType])
  @@index([organizationId])
}

model QuestProgress {
  id           String    @id @default(uuid())
  questId      String
  userId       String
  currentCount Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  quest        Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
  user         User  @relation("QuestProgressUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questId, userId])
  @@index([userId, isCompleted])
}

// ── SPARK DISMISS (masquer un spark du feed) ──

model SparkDismiss {
  id        String   @id @default(uuid())
  sparkId   String
  userId    String
  createdAt DateTime @default(now())

  spark     Spark @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  user      User  @relation("SparkDismissUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sparkId, userId])
  @@index([userId])
}

// ── SAVED REELS (sauvegarder un post/reel) ──

model SavedReel {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("SavedReelUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

// ── COMMENT LIKES (like sur un commentaire) ──

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   WallComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation("CommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

// ── GAMIFICATION (badges, niveaux, streaks) ──

model BadgeDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String                  // emoji ou URL
  category    String   @default("social") // social, creator, pro, loyalty
  criteria    String                  // ex: "posts_count >= 10"
  threshold   Int      @default(1)
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User            @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserStreak {
  id            String    @id @default(uuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime  @default(now())
  totalPoints   Int       @default(0)
  level         Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User @relation("UserStreakData", fields: [userId], references: [id], onDelete: Cascade)
}

// ── CONTENT MODERATION ──

model ContentReport {
  id             String    @id @default(uuid())
  reporterId     String
  targetType     String              // post, comment, spark, reel, user
  targetId       String
  reason         String              // spam, harassment, nudity, violence, other
  description    String?
  status         String    @default("pending") // pending, reviewed, resolved, dismissed
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  reporter       User  @relation("ContentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer       User? @relation("ContentReviewer", fields: [reviewedBy], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

// ── ÉVÉNEMENTS SOCIAUX ──

model SocialEvent {
  id             String    @id @default(uuid())
  organizationId String?
  creatorId      String
  title          String
  description    String?
  coverUrl       String?
  location       String?
  latitude       Float?
  longitude      Float?
  eventType      String    @default("meetup") // meetup, workshop, jobfair, openday, concert
  visibility     String    @default("ALL") // ALL, IN, OUT
  publishAsOrg   Boolean   @default(false)
  startsAt       DateTime
  endsAt         DateTime?
  maxAttendees   Int?
  isPublic       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User          @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  attendees      EventAttendee[]

  @@index([startsAt])
  @@index([organizationId])
  @@index([eventType, isPublic])
}

model EventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("going") // going, interested, declined
  createdAt DateTime @default(now())

  event     SocialEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User        @relation("EventAttendees", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}
