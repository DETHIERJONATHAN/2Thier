/// Fiches techniques / documents liés aux produits (panneaux, onduleurs, etc.)
/// Liés aux FieldOptionNode pour association automatique dans les devis
model ProductDocument {
  id             String                      @id @default(dbgenerated("(gen_random_uuid())::text"))
  /// Référence au TreeBranchLeafNode (champ/option de l'arbre)
  nodeId         String
  organizationId String
  /// Utilisateur qui a uploadé
  uploadedById   String
  /// Métadonnées du fichier
  /// Nom affiché (ex: "Fiche technique JA Solar 425W")
  name           String
  /// Nom du fichier original
  fileName       String
  mimeType       String                      @default("application/pdf")
  /// Taille en octets
  fileSize       Int?
  /// Stockage unifié
  storageType    DocumentStorageType         @default(LOCAL)
  /// Chemin local pour stockage CRM (users Yandex)
  localPath      String?
  /// ID fichier Google Drive (users Google)
  driveFileId    String?
  /// URL publique/partagée Google Drive
  driveUrl       String?
  /// URL externe (Yandex Disk ou autre)
  externalUrl    String?
  /// Catégorie pour filtrage
  /// fiche_technique, certification, garantie, notice
  category       String                      @default("fiche_technique")
  createdAt      DateTime                    @default(now()) @db.Timestamp(6)
  updatedAt      DateTime                    @updatedAt @db.Timestamp(6)
  /// Référence optionnelle à une ligne de table lookup
  tableRowId     String?
  node           TreeBranchLeafNode          @relation(fields: [nodeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tableRow       TreeBranchLeafNodeTableRow? @relation(fields: [tableRowId], references: [id], onUpdate: NoAction)
  uploadedBy     User                        @relation("ProductDocumentsUploaded", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([nodeId])
  @@index([tableRowId])
  @@index([organizationId])
  @@index([category])
  @@index([storageType])
}

