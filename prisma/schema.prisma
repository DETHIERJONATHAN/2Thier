  documentName          String?
  uploadedById          String?
  data                  Json?
  isValidated           Boolean            @default(false)
  validatedAt           DateTime?
  validatedById         String?
  validationNotes       String?
  plannedDate           DateTime?
  receptionDate         DateTime?
  deliveryDate          DateTime?
  completedDate         DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime

  Lead                  Lead?              @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ChantierStatus        ChantierStatus?    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Responsable           User?              @relation("ChantierResponsable", fields: [responsableId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Commercial            User?              @relation("ChantierCommercial", fields: [commercialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ValidatedBy           User?              @relation("ChantierValidator", fields: [validatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  GeneratedDocument     GeneratedDocument? @relation(fields: [generatedDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  TreeBranchLeafSubmission TreeBranchLeafSubmission? @relation(fields: [submissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ChantierInvoice        ChantierInvoice[]
  ChantierEvent          ChantierEvent[]
  ChantierHistory        ChantierHistory[]
  ChantierBillingPlanItem ChantierBillingPlanItem[]
  ChantierAssignments      ChantierAssignment[]
  TimeEntries              TimeEntry[]
  ChantierReception        ChantierReception?

  @@index([organizationId, createdAt])
  @@index([leadId])
  @@index([organizationId, productValue])
  @@index([generatedDocumentId])
  @@index([submissionId])
}

